{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slidev-dynamic-code-relay",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "name": "TALK_DO",
        "class_name": "TalkDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TalkDO"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
